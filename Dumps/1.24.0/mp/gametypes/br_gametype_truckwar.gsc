    level.shrink_poi_into_the_bank = [];
    level.shrink_poi_into_the_bank[0] = "assassination";
    level.shrink_poi_into_the_bank[1] = "domination";
    level.shrink_poi_into_the_bank[2] = "scavenger";
    level.reset_attacks_next_available_time = 0;
}

brtruck_initdialog()
{
    level endon( "game_ended" );
    level waittill( "br_dialog_initialized" );
}

brtruck_cleanupents()
{
    scripts\cp_mp\utility\game_utility::path_timeout( "delete_on_load", "targetname" );
    scripts\cp_mp\utility\game_utility::pathblocker( "door_prison_cell_metal_mp", 1 );
    scripts\cp_mp\utility\game_utility::pathblocker( "door_wooden_panel_mp_01", 1 );
    scripts\cp_mp\utility\game_utility::pathblocker( "me_electrical_box_street_01", 1 );
}

