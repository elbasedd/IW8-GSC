brtruck_initfeatures()
{
    if ( getdvarint( "scr_brtruck_debug", 0 ) == 1 )
    {
        scripts\mp\gametypes\br_gametypes.gsc::createdefaultrectangularzone( "circle" );
        scripts\mp\gametypes\br_gametypes.gsc::createdefaultrectangularzone( "gulag" );
        scripts\mp\gametypes\br_gametypes.gsc::createdefaultrectangularzone( "dropbag" );
        scripts\mp\gametypes\br_gametypes.gsc::createdefaultrectangularzone( "oneLife" );
        scripts\mp\gametypes\br_gametypes.gsc::decoy_aiseenplayerrecently( "allowLateJoiners" );
    }

    scripts\mp\gametypes\br_gametypes.gsc::createdefaultrectangularzone( "plunderSites" );
    scripts\mp\gametypes\br_gametypes.gsc::decoy_aiseenplayerrecently( "tabletReplace" );
}

brtruck_initpostmain()
{
    scripts\mp\gametypes\br_gametypes.gsc::onplayergetsplunder( "playerWelcomeSplashes", ::brtruck_playerwelcomesplashes );
    waittillframeend;
    level.ontimelimit = ::brtruck_ontimelimit;
