brking_watchcircletimers()
{
    level endon( "game_ended" );
    level.circleclosestarttime = gettime();

    for (;;)
    {
        level waittill( "br_circle_started" );
        level.circleclosestarttime = gettime();
    }
}

brking_getcirclepercentmoved()
{
    return ( gettime() - level.circleclosestarttime ) / 1000 / level.ks_circleclosetime;
}

brking_getcenterofcircle()
{
    var_0 = brking_getcirclepercentmoved();

    if ( level.br_circle.circleindex < 0 )
        return level.br_level.br_circlecenters[0];

    if ( var_0 > 1 )
        return level.br_level.br_circlecenters[level.br_circle.circleindex];

    var_1 = level.br_level.br_circlecenters[level.br_circle.circleindex + 1];
    var_2 = level.br_level.br_circlecenters[level.br_circle.circleindex];
    return vectorlerp( var_2, var_1, brking_getcirclepercentmoved() );
}

brking_ispointinmovingcircle( var_0 )
{
    var_1 = brking_getcenterofcircle();
    var_2 = distance2d( var_0, var_1 );
    return var_2 < level.ks_circleradius;
}

brking_getrandompointinmovingcircle( var_0, var_1 )
{
    var_2 = brking_getcenterofcircle();
    return scripts\mp\gametypes\br_circle.gsc::getrandompointincircle( var_2, level.ks_circleradius, var_0, var_1 );
}

attachkingflag()
{
    if ( !isdefined( self.carryflag ) )
    {
        self attach( "prop_king_game_flag", "tag_stowed_back3", 1 );
        self.carryflag = "prop_ctf_game_flag_west";
        self setclientomnvar( "ui_ctf_flag_carrier", 1 );
    }
}

detachkingflag()
{
    if ( isdefined( self.carryflag ) )
    {
        self detach( "prop_king_game_flag", "tag_stowed_back3" );
        self.carryflag = undefined;
        self setclientomnvar( "ui_ctf_flag_carrier", 0 );
    }
}
